@model IEnumerable<Team>

<h2>Team List</h2>

<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Points</th>
            <th>Player Count</th>
            <th>Details</th>
        </tr>
    </thead>
    <tbody>
        @foreach (Team team in Model)
        {
            <tr>
                <td>@team.Id</td>
                <td>@team.Name</td>
                <td>@team.Points</td>
                <td>@(team.Players?.Count ?? 0)</td>
                <td><a href="/Team/Details/@team.Id">View</a></td>
            </tr>
        }
    </tbody>
</table>
