@model Team

<h2>Team Details</h2>

<div>
    <h3>@Model.Name</h3>
    <p><strong>Points:</strong> @Model.Points</p>
    <p><strong>Player Count:</strong> @(Model.Players?.Count ?? 0)</p>

    <h4>Players:</h4>
    @if (Model.Players != null && Model.Players.Count > 0)
    {
        <ul>
            @foreach (var player in Model.Players)
            {
                <li>@player.Name (Market Value: @player.MarketValue)</li>
                <a href="/Player/Details/@player.Id">View Player Details</a>
            }
        </ul>
    }
    else
    {
        <p>No players in this team.</p>
    }